{
  "Routes": [

    // 🔐 AUTH (IdentityService)
    {
      "DownstreamPathTemplate": "/api/auth/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5085
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/{everything}",
      "UpstreamHttpMethod": [ "POST", "GET" ],
      "SwaggerKey": "identity",
      "Priority": 1
    },

    // 🛒 CATALOG (GENERAL - KEEP LOW PRIORITY)
    {
      "DownstreamPathTemplate": "/api/products/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5191
        }
      ],
      "UpstreamPathTemplate": "/gateway/products/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ],
      "SwaggerKey": "catalog",
      "Priority": 0
    },

    // 🔄 WORKFLOW
    {
      "DownstreamPathTemplate": "/api/workflow/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5038
        }
      ],
      "UpstreamPathTemplate": "/gateway/workflow/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT" ],
      "SwaggerKey": "workflow",
      "Priority": 1
    },

    // 📊 ADMIN
    {
      "DownstreamPathTemplate": "/api/reports/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5136
        }
      ],
      "UpstreamPathTemplate": "/gateway/reports/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "admin",
      "Priority": 2
    },
    {
      "DownstreamPathTemplate": "/api/audit/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5136
        }
      ],
      "UpstreamPathTemplate": "/gateway/audit/{everything}",
      "UpstreamHttpMethod": [ "GET" ],
      "SwaggerKey": "admin",
      "Priority": 2
    }

  ],

  "GlobalConfiguration": {
    "BaseUrl": "http://localhost:5163"
  }
}