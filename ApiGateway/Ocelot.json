        {
          "Host": "localhost",
          "Port": 5191
        }
      ],
      "UpstreamPathTemplate": "/gateway/products/{id}/status",
      "UpstreamHttpMethod": [ "PUT" ]
    },
    {
      "DownstreamPathTemplate": "/api/products/paged",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5191
        }
      ],
      "UpstreamPathTemplate": "/gateway/products/paged",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "DownstreamPathTemplate": "/api/products/plp",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5191
        }
      ],
      "UpstreamPathTemplate": "/gateway/products/plp",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "DownstreamPathTemplate": "/api/products/audit/paged",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5191
        }
      ],
      "UpstreamPathTemplate": "/gateway/products/audit/paged",
      "UpstreamHttpMethod": [ "GET" ]
    },

    // 🔄 WORKFLOW
    {
      "DownstreamPathTemplate": "/api/workflow/{everything}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5038
        }
      ],
      "UpstreamPathTemplate": "/gateway/workflow/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT" ]
    },

    // 📊 ADMIN / REPORTING
    {
      "DownstreamPathTemplate": "/api/reports/dashboard",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5136
        }
      ],
      "UpstreamPathTemplate": "/gateway/reports/dashboard",
      "UpstreamHttpMethod": [ "GET" ]
    },
    {
      "DownstreamPathTemplate": "/api/audit/products/{id}",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 5136
        }
      ],
      "UpstreamPathTemplate": "/gateway/audit/products/{id}",
      "UpstreamHttpMethod": [ "GET" ]
    }

